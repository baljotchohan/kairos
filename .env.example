# ── Fireworks AI (AMD hardware — required for hackathon) ──────────────────────
FIREWORKS_API_KEY=your_key_here
FIREWORKS_MODEL=accounts/fireworks/models/qwen3p7-plus
# Cheap/fast model for high-volume ingestion extraction
FIREWORKS_MODEL_FAST=accounts/fireworks/models/llama-v3p3-70b-instruct
# Gemma 4 26B-A4B (MoE, 3.8B active) — used by the Intent Agent for cheap/fast classification
FIREWORKS_MODEL_GEMMA=accounts/fireworks/models/gemma-4-26b-a4b-it

# ── Groq + Gemini (optional fallback chain — resilience if Fireworks is down) ──
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-2

# ── Memory ─────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
SQLITE_PATH=./kairos.db
OBSIDIAN_VAULT=./obsidian_vault

# ── Slack ──────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN — required for @KAIROS mention responses (Socket Mode)
# Get it from: https://api.slack.com/apps → your app → Settings → Basic Information
# → App-level tokens → Generate token with "connections:write" scope
SLACK_APP_TOKEN=xapp-your-token
# OAuth App credentials (https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Google Workspace (Gmail + Drive) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ── Zoom ───────────────────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=your_account_id
ZOOM_CLIENT_ID=your_client_id
ZOOM_CLIENT_SECRET=your_client_secret
# Global Server-to-Server fallback (allow_s2s) is gated to this one uid only —
# every other user's Zoom connector is per-user OAuth, no fallback.
ZOOM_OWNER_UID=

# ── Notion ─────────────────────────────────────────────────────────────────────
# OAuth app: notion.so/my-integrations → New connection → OAuth type
# Set Redirect URI: https://your-backend.hf.space/api/oauth/notion/callback
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret
# Fallback/admin integration key (manual-key path, no OAuth) — optional
NOTION_API_KEY=

# ── GitHub ─────────────────────────────────────────────────────────────────────
# OAuth App: github.com/settings/developers → New OAuth App
# Set Authorization callback URL: https://your-backend.hf.space/api/oauth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Jira ───────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=admin@yourcompany.com
JIRA_API_TOKEN=your_api_token
# OAuth App credentials (https://developer.atlassian.com/console/myapps)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=
# Until JIRA_CLIENT_ID/SECRET are registered, the global credentials above are
# usable only by this one uid — every other user sees Jira as disconnected.
JIRA_OWNER_UID=

# ── App ────────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
DEBUG=false
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
# Gates the Helios Tech demo dataset — only the login matching DEMO_LOGIN_EMAIL
# ever sees it, and it's only seeded at all if SEED_DEMO_DATA=true.
SEED_DEMO_DATA=false
DEMO_USER_ID=demo-helios
DEMO_LOGIN_EMAIL=demo@kairos.app

# ── MCP ────────────────────────────────────────────────────────────────────────
# REQUIRED in production: signs per-user MCP connect tokens.
# Must be stable across restarts or every user's connector URL breaks.
# Generate once: python -c "import secrets; print(secrets.token_hex(32))"
MCP_CONNECT_SECRET=generate_a_random_32byte_hex_value_here

# ── Ingestion tuning ───────────────────────────────────────────────────────────
SLACK_LOOKBACK_DAYS=30
EMAIL_LOOKBACK_DAYS=30
INGEST_INTERVAL_MINUTES=60
MAX_MESSAGES_PER_CHANNEL=500
# Caps LLM extraction calls per ingestion cycle, to stay under provider TPM limits
MAX_EXTRACT_PER_CYCLE=24
EXTRACT_DELAY_SECONDS=4
# Hard ceiling on a single run_ingestion() call, so a hung connector/LLM call
# can't hold a user's ingestion lock forever
INGESTION_TIMEOUT_SECONDS=600
