# ── Fireworks AI (AMD hardware — required for hackathon) ──────────────────────
FIREWORKS_API_KEY=your_key_here
FIREWORKS_MODEL=accounts/fireworks/models/qwen2p5-72b-instruct

# ── Memory ─────────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
SQLITE_PATH=./kairos.db
OBSIDIAN_VAULT=./obsidian_vault

# ── Slack ──────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN — required for @KAIROS mention responses (Socket Mode)
# Get it from: https://api.slack.com/apps → your app → Settings → Basic Information
# → App-level tokens → Generate token with "connections:write" scope
SLACK_APP_TOKEN=xapp-your-token
# OAuth App credentials (https://api.slack.com/apps)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# ── Google Workspace (Gmail + Drive) ───────────────────────────────────────────
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# ── Zoom ───────────────────────────────────────────────────────────────────────
ZOOM_ACCOUNT_ID=your_account_id
ZOOM_CLIENT_ID=your_client_id
ZOOM_CLIENT_SECRET=your_client_secret

# ── Notion ─────────────────────────────────────────────────────────────────────
# OAuth app: notion.so/my-integrations → New connection → OAuth type
# Set Redirect URI: https://your-backend.hf.space/api/oauth/notion/callback
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret

# ── GitHub ─────────────────────────────────────────────────────────────────────
# OAuth App: github.com/settings/developers → New OAuth App
# Set Authorization callback URL: https://your-backend.hf.space/api/oauth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Jira ───────────────────────────────────────────────────────────────────────
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=admin@yourcompany.com
JIRA_API_TOKEN=your_api_token
# OAuth App credentials (https://developer.atlassian.com/console/myapps)
JIRA_CLIENT_ID=
JIRA_CLIENT_SECRET=

# ── App ────────────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
DEBUG=false
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ── MCP ────────────────────────────────────────────────────────────────────────
# REQUIRED in production: signs per-user MCP connect tokens.
# Must be stable across restarts or every user's connector URL breaks.
# Generate once: python -c "import secrets; print(secrets.token_hex(32))"
MCP_CONNECT_SECRET=generate_a_random_32byte_hex_value_here

# ── Ingestion tuning ───────────────────────────────────────────────────────────
SLACK_LOOKBACK_DAYS=30
EMAIL_LOOKBACK_DAYS=30
INGEST_INTERVAL_MINUTES=60
MAX_MESSAGES_PER_CHANNEL=500
